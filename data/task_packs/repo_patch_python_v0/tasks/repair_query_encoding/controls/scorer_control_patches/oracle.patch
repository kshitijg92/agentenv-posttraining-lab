diff --git a/src/query.py b/src/query.py
index d72f98d..755ef88 100644
--- a/src/query.py
+++ b/src/query.py
@@ -1,3 +1,28 @@
-def encode_query(params: dict[str, str]) -> str:
+from collections.abc import Mapping, Sequence
+from urllib.parse import quote
+
+
+def encode_query(params: Mapping[str, str | Sequence[str]]) -> str:
     """Encode query parameters into a deterministic query string."""
-    return "&".join(f"{key}={value}" for key, value in params.items())
+    if not isinstance(params, Mapping):
+        raise ValueError("params must be a mapping")
+    if any(not isinstance(key, str) for key in params):
+        raise ValueError("query keys must be strings")
+    pairs: list[tuple[str, str]] = []
+    for key in sorted(params):
+        raw_value = params[key]
+        if isinstance(raw_value, str):
+            values = [raw_value]
+        elif isinstance(raw_value, Sequence) and not isinstance(
+            raw_value, (bytes, bytearray)
+        ):
+            values = list(raw_value)
+        else:
+            raise ValueError("query values must be strings or string sequences")
+        if any(not isinstance(value, str) for value in values):
+            raise ValueError("query sequence values must be strings")
+        pairs.extend((key, value) for value in values)
+    return "&".join(
+        f"{quote(key, safe='')}={quote(value, safe='')}"
+        for key, value in pairs
+    )
