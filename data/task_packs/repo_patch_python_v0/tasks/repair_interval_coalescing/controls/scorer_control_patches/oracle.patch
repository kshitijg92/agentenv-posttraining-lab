+    if not validated:
         return []
-    merged = [intervals[0]]
-    for start, end in intervals[1:]:
+    merged = [validated[0]]
+    for start, end in validated[1:]:
         previous_start, previous_end = merged[-1]
         if start <= previous_end:
             merged[-1] = (previous_start, max(previous_end, end))
         else:
             merged.append((start, end))
     return merged
