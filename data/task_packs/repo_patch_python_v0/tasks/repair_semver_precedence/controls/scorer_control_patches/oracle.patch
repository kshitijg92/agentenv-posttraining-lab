+import re
+
+
+_SEMVER_RE = re.compile(
+    r"(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(?:-([0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*))?",
+    re.ASCII,
+)
+
+
+def _parse(value: object) -> tuple[tuple[int, int, int], tuple[str, ...] | None]:
+    if not isinstance(value, str):
+        raise ValueError("version must be a string")
+    match = _SEMVER_RE.fullmatch(value)
+    if match is None:
+        raise ValueError("invalid semantic version")
+    core = tuple(int(part) for part in match.groups()[:3])
+    prerelease = match.group(4)
+    if prerelease is not None:
+        identifiers = tuple(prerelease.split("."))
+        for identifier in identifiers:
+            if identifier.isdigit() and len(identifier) > 1 and identifier[0] == "0":
+                raise ValueError("numeric prerelease identifiers forbid leading zeros")
+    else:
+        identifiers = None
+    return (core[0], core[1], core[2]), identifiers
+
+
+def _compare_prerelease(left: tuple[str, ...], right: tuple[str, ...]) -> int:
+    for left_id, right_id in zip(left, right):
+        left_numeric = left_id.isdigit()
+        right_numeric = right_id.isdigit()
+        if left_numeric and right_numeric:
+            comparison = (int(left_id) > int(right_id)) - (int(left_id) < int(right_id))
+        elif left_numeric:
+            return -1
+        elif right_numeric:
+            return 1
+        else:
+            comparison = (left_id > right_id) - (left_id < right_id)
+        if comparison:
+            return comparison
+    return (len(left) > len(right)) - (len(left) < len(right))
+
+
 def compare_semver(left: str, right: str) -> int:
     """Compare two version strings."""
-    return (left > right) - (left < right)
+    left_core, left_prerelease = _parse(left)
+    right_core, right_prerelease = _parse(right)
+    core_comparison = (left_core > right_core) - (left_core < right_core)
+    if core_comparison:
+        return core_comparison
+    if left_prerelease is None and right_prerelease is None:
+        return 0
+    if left_prerelease is None:
+        return 1
+    if right_prerelease is None:
+        return -1
+    return _compare_prerelease(left_prerelease, right_prerelease)
