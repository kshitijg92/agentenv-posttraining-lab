+def _validated_columns(columns: object) -> list[str]:
+    if isinstance(columns, (str, bytes)):
+        raise ValueError("columns must be a non-string iterable")
+    try:
+        selected = list(columns)  # type: ignore[arg-type]
+    except TypeError as exc:
+        raise ValueError("columns must be iterable") from exc
+    if not selected:
+        raise ValueError("at least one column is required")
+    if any(not isinstance(column, str) or not column for column in selected):
+        raise ValueError("column names must be non-empty strings")
+    if len(set(selected)) != len(selected):
+        raise ValueError("requested columns must be unique")
+    return selected
+
